# Django Core Configuration
SECRET_KEY='xxx'
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,siem.seclink.info,backend

# PostgreSQL Database Configuration
POSTGRES_DB=siem_db
POSTGRES_USER=siem_user
POSTGRES_PASSWORD=siem_password
POSTGRES_HOST=db
POSTGRES_PORT=5432

# CSRF Trusted Origins (comma-separated, no spaces)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Elasticsearch Configuration (optional, for ES integration)
ES_HOST=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=your-es-password

# Tickets API (for orchestrator ticket creation)
TICKETS_API_BASE=http://localhost:8000/api/v1/tickets/
TICKETS_API_TOKEN=your-token-here

# frontend environment variable for backend API origin
BACKEND_ORIGIN=http://backend:8000

# OTP Authentication / Registration
OTP_AUTH_ENABLED=true
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_HASH_SECRET=change-me-in-production
ADMIN_REGISTRATION_EMAILS=customer@xx.xx
OTP_EMAIL_RETRY_ATTEMPTS=3
OTP_EMAIL_RETRY_BACKOFF_SECONDS=1
OTP_EMAIL_COOLDOWN_SECONDS=60
OTP_EMAIL_LIMIT_COUNT=3
OTP_EMAIL_LIMIT_WINDOW_SECONDS=600
OTP_IP_LIMIT_COUNT=10
OTP_IP_LIMIT_WINDOW_SECONDS=300
REJECT_ADMIN_LIMIT_COUNT=30
REJECT_ADMIN_LIMIT_WINDOW_SECONDS=3600
REJECT_IP_LIMIT_COUNT=30
REJECT_IP_LIMIT_WINDOW_SECONDS=3600
AUDIT_LOGS_RATE=120/hour
AUDIT_LOG_RETENTION_DAYS=90
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0

# Email / SMTP (for OTP and notifications)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.feishu.cn
EMAIL_PORT=587
EMAIL_HOST_USER=customer@xx.xx
EMAIL_HOST_PASSWORD=xxxx
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
DEFAULT_FROM_EMAIL=customer@xx.xx
EMAIL_TIMEOUT=15